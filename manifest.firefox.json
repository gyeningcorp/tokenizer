{
  "manifest_version": 2,
  "name": "Tokenizer — Live Token & Cost Monitor",
  "version": "0.5.0",
  "description": "Live token counting on every LLM as you type. See tokens, cost, and cross-model comparison on 30+ AI platforms.",

  "permissions": [
    "activeTab",
    "storage",
    "https://chat.openai.com/*",
    "https://chatgpt.com/*",
    "https://claude.ai/*",
    "https://gemini.google.com/*",
    "https://www.perplexity.ai/*",
    "https://perplexity.ai/*",
    "https://grok.com/*",
    "https://x.com/*",
    "https://chat.deepseek.com/*",
    "https://chat.mistral.ai/*",
    "https://copilot.microsoft.com/*",
    "https://meta.ai/*",
    "https://huggingface.co/*",
    "https://poe.com/*",
    "https://you.com/*",
    "https://pi.ai/*",
    "https://coral.cohere.com/*",
    "https://chat.lmsys.org/*",
    "https://cursor.com/*",
    "https://bolt.new/*",
    "https://v0.dev/*",
    "https://replit.com/*",
    "https://phind.com/*",
    "https://devv.ai/*",
    "https://codeium.com/*",
    "https://app.fireworks.ai/*",
    "https://console.groq.com/*",
    "https://app.together.ai/*",
    "https://sdk.vercel.ai/*",
    "https://aistudio.google.com/*",
    "https://platform.openai.com/*",
    "https://console.anthropic.com/*",
    "https://lmstudio.ai/*",
    "https://jan.ai/*",
    "https://msty.app/*"
  ],

  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },

  "content_scripts": [
    {
      "matches": [
        "https://chat.openai.com/*",
        "https://chatgpt.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://www.perplexity.ai/*",
        "https://perplexity.ai/*",
        "https://grok.com/*",
        "https://x.com/i/grok*",
        "https://chat.deepseek.com/*",
        "https://chat.mistral.ai/*",
        "https://copilot.microsoft.com/*",
        "https://meta.ai/*",
        "https://huggingface.co/chat/*",
        "https://poe.com/*",
        "https://you.com/*",
        "https://pi.ai/*",
        "https://coral.cohere.com/*",
        "https://chat.lmsys.org/*",
        "https://cursor.com/*",
        "https://bolt.new/*",
        "https://v0.dev/*",
        "https://replit.com/*",
        "https://phind.com/*",
        "https://devv.ai/*",
        "https://codeium.com/*",
        "https://app.fireworks.ai/*",
        "https://console.groq.com/*",
        "https://app.together.ai/*",
        "https://sdk.vercel.ai/*",
        "https://aistudio.google.com/*",
        "https://platform.openai.com/playground*",
        "https://console.anthropic.com/*",
        "https://lmstudio.ai/*",
        "https://jan.ai/*",
        "https://msty.app/*"
      ],
      "js": ["content.js"],
      "css": ["overlay.css"],
      "run_at": "document_idle"
    }
  ],

  "web_accessible_resources": ["injected.js"],

  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "tokenizer@thedigitalduo.net",
      "strict_min_version": "109.0"
    }
  }
}


