{
  "manifest_version": 3,
  "name": "Tokenizer Live Token and Cost Monitor",
  "version": "0.7.0",
  "description": "Real-time token counts, costs & energy usage on ChatGPT, Claude, Gemini, Grok, DeepSeek + 25 more. Free, open source.",

  "browser_specific_settings": {
    "gecko": {
      "id": "tokenizer@gyeningcorp.com",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },

  "permissions": ["storage"],

  "host_permissions": [
    "https://chat.openai.com/*",
    "https://chatgpt.com/*",
    "https://claude.ai/*",
    "https://gemini.google.com/*",
    "https://www.perplexity.ai/*",
    "https://perplexity.ai/*",
    "https://grok.com/*",
    "https://x.com/*",
    "https://chat.deepseek.com/*",
    "https://chat.mistral.ai/*",
    "https://copilot.microsoft.com/*",
    "https://meta.ai/*",
    "https://huggingface.co/*",
    "https://poe.com/*",
    "https://you.com/*",
    "https://pi.ai/*",
    "https://coral.cohere.com/*",
    "https://chat.lmsys.org/*",
    "https://cursor.com/*",
    "https://bolt.new/*",
    "https://v0.dev/*",
    "https://replit.com/*",
    "https://phind.com/*",
    "https://devv.ai/*",
    "https://codeium.com/*",
    "https://app.fireworks.ai/*",
    "https://console.groq.com/*",
    "https://app.together.ai/*",
    "https://sdk.vercel.ai/*",
    "https://aistudio.google.com/*",
    "https://platform.openai.com/*",
    "https://console.anthropic.com/*",
    "https://lmstudio.ai/*",
    "https://jan.ai/*",
    "https://msty.app/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],

  "background": {
    "scripts": ["background.js"]
  },

  "content_scripts": [
    {
      "matches": [
        "https://chat.openai.com/*",
        "https://chatgpt.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://www.perplexity.ai/*",
        "https://perplexity.ai/*",
        "https://grok.com/*",
        "https://x.com/i/grok*",
        "https://chat.deepseek.com/*",
        "https://chat.mistral.ai/*",
        "https://copilot.microsoft.com/*",
        "https://meta.ai/*",
        "https://huggingface.co/chat/*",
        "https://poe.com/*",
        "https://you.com/*",
        "https://pi.ai/*",
        "https://coral.cohere.com/*",
        "https://chat.lmsys.org/*",
        "https://cursor.com/*",
        "https://bolt.new/*",
        "https://v0.dev/*",
        "https://replit.com/*",
        "https://phind.com/*",
        "https://devv.ai/*",
        "https://codeium.com/*",
        "https://app.fireworks.ai/*",
        "https://console.groq.com/*",
        "https://app.together.ai/*",
        "https://sdk.vercel.ai/*",
        "https://aistudio.google.com/*",
        "https://platform.openai.com/playground*",
        "https://platform.openai.com/codex*",
        "https://console.anthropic.com/*",
        "https://lmstudio.ai/*",
        "https://jan.ai/*",
        "https://msty.app/*",
        "http://localhost/*",
        "http://127.0.0.1/*"
      ],
      "js": ["content.js"],
      "css": ["overlay.css"],
      "run_at": "document_idle"
    }
  ],

  "web_accessible_resources": [
    {
      "resources": ["injected.js"],
      "matches": ["<all_urls>"]
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}

